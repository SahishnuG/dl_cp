# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/karmafit_db

# Clerk JWT verification settings
# Replace <your-clerk-domain> with your Clerk frontend API domain if needed.
# Example: https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json

# Optional strict checks (leave blank to disable)
CLERK_ISSUER=
CLERK_AUDIENCE=
